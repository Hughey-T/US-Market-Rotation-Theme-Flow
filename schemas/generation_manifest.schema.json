{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/us-market-rotation/generation_manifest.schema.1.0.json",
  "title": "Market Rotation generation manifest 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["publication_contract_version", "generation_version", "analysis_id", "generation_id", "run_id", "data_date", "generated_at", "source_commit", "source_sha256", "previous_generation_id", "files"],
  "properties": {
    "publication_contract_version": {"const": "1.0"},
    "generation_version": {"const": "1.0"},
    "analysis_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generation_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "run_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "data_date": {"type": "string", "format": "date"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "previous_generation_id": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[a-f0-9]{64}$"}]},
    "files": {
      "type": "object", "additionalProperties": false,
      "required": ["archive.json", "history.json", "judgment-index.json", "latest.json"],
      "properties": {
        "archive.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "history.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "judgment-index.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "latest.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
