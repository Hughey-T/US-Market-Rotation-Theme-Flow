{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/us-market-rotation/consumer_snapshot.schema.1.0.json",
  "title": "Custom GPT lightweight consumer snapshot 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["consumer_contract_version", "source_identity", "meta", "user_view"],
  "properties": {
    "consumer_contract_version": {"const": "1.0"},
    "source_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analysis_id", "generation_id"],
      "properties": {
        "analysis_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "generation_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "source_commit", "source_snapshot", "source_sha256", "generated_at", "data_date", "valid_until", "hard_stop_after", "status", "failure_reason", "global_quality"],
      "properties": {
        "run_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "source_snapshot": {"type": "string", "pattern": "^output/generations/[a-f0-9]{64}/archive\\.json$"},
        "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "generated_at": {"type": "string", "format": "date-time"},
        "data_date": {"type": "string", "format": "date"},
        "valid_until": {"type": "string", "format": "date-time"},
        "hard_stop_after": {"type": "string", "format": "date-time"},
        "status": {"enum": ["success", "failed"]},
        "failure_reason": {"anyOf": [{"type": "null"}, {"type": "string"}]},
        "global_quality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["critical_missing", "warnings"],
          "properties": {
            "critical_missing": {"type": "array", "items": {"type": "string"}},
            "warnings": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "user_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["presentation_version", "analysis_mode", "phases"],
      "properties": {
        "presentation_version": {"enum": ["1.1", "1.2"]},
        "analysis_mode": {"enum": ["initial_observation", "trend"]},
        "phases": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["conclusion", "investment_meaning", "cautions", "next_checks"],
            "properties": {
              "conclusion": {"type": "string", "minLength": 1},
              "investment_meaning": {"type": "string", "minLength": 1},
              "cautions": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "next_checks": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          }
        }
      }
    }
  }
}
