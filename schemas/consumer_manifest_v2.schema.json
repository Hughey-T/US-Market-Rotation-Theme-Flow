{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/us-market-rotation/consumer_manifest.schema.2.0.json",
  "title": "Custom GPT small-payload consumer manifest 2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consumer_contract_version",
    "source_identity",
    "meta",
    "presentation",
    "phase_inventory",
    "detail_inventory"
  ],
  "properties": {
    "consumer_contract_version": {
      "const": "2.0"
    },
    "source_identity": {
      "$ref": "#/$defs/sourceIdentity"
    },
    "meta": {
      "$ref": "#/$defs/manifestMeta"
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "presentation_version",
        "analysis_mode"
      ],
      "properties": {
        "presentation_version": {
          "const": "1.2"
        },
        "analysis_mode": {
          "enum": [
            "initial_observation",
            "trend"
          ]
        }
      }
    },
    "phase_inventory": {
      "$ref": "#/$defs/inventory"
    },
    "detail_inventory": {
      "$ref": "#/$defs/inventory"
    }
  },
  "$defs": {
    "sourceIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "generation_id"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "generation_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "manifestMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "source_commit",
        "source_snapshot",
        "source_sha256",
        "generated_at",
        "data_date",
        "valid_until",
        "hard_stop_after",
        "status",
        "failure_reason",
        "global_quality"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "source_snapshot": {
          "type": "string",
          "pattern": "^output/generations/[a-f0-9]{64}/archive\\.json$"
        },
        "source_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "data_date": {
          "type": "string",
          "format": "date"
        },
        "valid_until": {
          "type": "string",
          "format": "date-time"
        },
        "hard_stop_after": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "const": "success"
        },
        "failure_reason": {
          "const": null
        },
        "global_quality": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "critical_missing",
            "warnings"
          ],
          "properties": {
            "critical_missing": {
              "type": "array",
              "maxItems": 0,
              "items": {
                "type": "string"
              }
            },
            "warnings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "inventory": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase",
          "part_count"
        ],
        "properties": {
          "phase": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "part_count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 999
          }
        }
      }
    }
  }
}
