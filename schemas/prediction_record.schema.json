{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prediction_record.schema.json",
  "title": "Market Rotation Prediction Record 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["prediction_schema_version", "data_date", "run_id", "regime", "predictions", "next_check"],
  "properties": {
    "prediction_schema_version": {"const": "1.0"},
    "data_date": {"type": "string", "format": "date"},
    "run_id": {"type": "string", "minLength": 10},
    "regime": {"type": "string", "minLength": 1},
    "predictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["theme_id", "phase", "flow_evidence", "action", "thesis", "key_metrics", "withdrawal_conditions", "dd_candidates"],
        "properties": {
          "theme_id": {"type": "string", "minLength": 1},
          "phase": {"enum": ["初動", "拡散", "過熱", "流出", "判定不能"]},
          "flow_evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["level", "direction"],
            "properties": {
              "level": {"enum": ["直接証拠", "間接証拠", "価格のみ", "証拠不足"]},
              "direction": {"enum": ["流入示唆", "流出示唆", "上昇", "下落", "不明"]}
            }
          },
          "action": {"enum": ["DDへ", "条件付き監視", "待機", "流出中", "判定不能"]},
          "thesis": {"type": "string", "minLength": 1},
          "key_metrics": {"type": "object", "additionalProperties": {"type": ["number", "null"]}},
          "withdrawal_conditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field", "operator", "threshold", "persistence_weeks"],
              "properties": {
                "field": {"type": "string", "minLength": 1},
                "operator": {"enum": ["<", "<=", ">", ">=", "=="]},
                "threshold": {"type": "number"},
                "persistence_weeks": {"type": "integer", "minimum": 1, "maximum": 12}
              }
            }
          },
          "dd_candidates": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ticker", "role", "reason"],
              "properties": {
                "ticker": {"type": "string", "minLength": 1},
                "role": {"enum": ["core", "beneficiary", "peripheral"]},
                "reason": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "next_check": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
